{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' https://img.youtube.com https://i.ytimg.com https://*.googleusercontent.com data:; connect-src 'self' https://vitals.vercel-insights.com; frame-src https://www.youtube-nocookie.com; frame-ancestors 'none'" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/mine", "schedule": "0 6 * * *" },
    { "path": "/api/autopilot", "schedule": "30 20 * * *" }
  ],
  "redirects": [
    { "source": "/library", "destination": "/feed", "permanent": true },
    { "source": "/studio", "destination": "/create", "permanent": true },
    { "source": "/profile", "destination": "/account", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/auth/google", "destination": "/api/auth/google" },
    { "source": "/api/mine", "destination": "/api/mine" },
    { "source": "/api/hooks", "destination": "/api/hooks" },
    { "source": "/api/auth/callback", "destination": "/api/auth/callback" },
    { "source": "/api/auth/me", "destination": "/api/auth/me" },
    { "source": "/api/auth/link-stripe", "destination": "/api/auth/callback" },
    { "source": "/api/checkout", "destination": "/api/checkout" },
    { "source": "/api/webhook", "destination": "/api/webhook" },
    { "source": "/api/profile", "destination": "/api/profile" },
    { "source": "/api/carousel", "destination": "/api/carousel" },
    { "source": "/api/social", "destination": "/api/social" },
    { "source": "/api/autopilot", "destination": "/api/autopilot" },
    { "source": "/feed", "destination": "/feed.html" },
    { "source": "/create", "destination": "/create.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" }
  ],
  "functions": {
    "api/autopilot.js": { "includeFiles": "{fonts/**,slide-render.mjs}" }
  }
}
